table 'State city master'
	lineageTag: 2193d597-7bb6-45d0-a6cc-ce93adfc97e4

	measure 'Highest Failing State' =
			
			VAR T =
			    TOPN(
			        1,
			        SUMMARIZE(
			            'State city master',
			            'State city master'[State],
			            "Failure", SUM('State city master'[Custom])
			        ),
			        [Failure],
			        DESC
			    )
			RETURN
			MAXX(T, [State])
		formatString: 0
		lineageTag: ef2879fc-a69f-4678-bd36-b93a840b6046

	measure Failing% = Calculate(SUM('State city master'[Custom]),'State city master'[State]="Delhi")
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c1a09969-f5c9-4e16-b6a6-f7ad043a8262

