annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["RNPs","RNP Number","Early / Late Life","Failure %age","Frequency of repetition","Table","svc engg","Parts replacement","Sample","Defects Repetition Branch Wise","Product Defect%","Trend","Stability index","P/N","Active/ Inactive Calls","ASC/DSC","Branch wise ASC/DSC","ASC/DSC Defects","active aging","Open/hold defects","Page Navigation","Open/Hold KPI","Warranty Type KPI","Active SVC KPI","Failing component","State city master","Month wise summary","Sub-product","Service call Aging","Engineer performance","RNP >180","Decomposition","Defect Code analysis","Primary Synotom Analysis","SVC  info"]

annotation PBI_ProTooling = ["DevMode"]

