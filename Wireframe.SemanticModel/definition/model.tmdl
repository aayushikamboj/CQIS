model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-IN
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_QueryOrder = ["RNPs","RNP Number","Early / Late Life","Failure %age","Frequency of repetition","Table","svc engg","Parts replacement","Sample","Defects Repetition Branch Wise","Product Defect%","Trend","Stability index","P/N","Active/ Inactive Calls","ASC/DSC","Branch wise ASC/DSC","ASC/DSC Defects","active aging","Open/hold defects","Page Navigation","Open/Hold KPI","Warranty Type KPI","Active SVC KPI","Failing component","State city master","Month wise summary","Sub-product","Service call Aging","Engineer performance"]

annotation PBI_ProTooling = ["DevMode"]

ref table RNPs
ref table 'RNP Number'
ref table 'Early / Late Life'
ref table 'Failure %age'
ref table 'Frequency of repetition'
ref table Table
ref table 'svc engg'
ref table 'Parts replacement'
ref table Sample
ref table 'Defects Repetition Branch Wise'
ref table 'Product Defect%'
ref table Trend
ref table 'Stability index'
ref table P/N
ref table 'Active/ Inactive Calls'
ref table ASC/DSC
ref table 'Branch wise ASC/DSC'
ref table 'ASC/DSC Defects'
ref table 'active aging'
ref table 'Open/hold defects'
ref table 'Page Navigation'
ref table 'Open/Hold KPI'
ref table 'Warranty Type KPI'
ref table 'Active SVC KPI'
ref table 'Failing component'
ref table 'State city master'
ref table 'Month wise summary'
ref table Sub-product
ref table 'Service call Aging'
ref table 'Engineer performance'

ref cultureInfo en-US

